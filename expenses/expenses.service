[Unit]
Description=Expenses portal (litestream-supervised Flask app)
After=network.target

[Service]
User=exedev
WorkingDirectory=/opt/expenses
EnvironmentFile=/opt/expenses/litestream.env
ExecStart=/usr/bin/litestream replicate -config /opt/expenses/litestream.yml \
    -exec "/usr/local/bin/uv run python app.py"
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
